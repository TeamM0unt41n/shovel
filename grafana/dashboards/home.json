          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH config AS (SELECT \n    (1000000 * EXTRACT(EPOCH FROM '${CTF_START_DATE}'::timestamp)) AS ctf_start_ts,\n    (1000000 * '${CTF_TICK_LENGTH}'::bigint) AS tick_length\n)\nSELECT\n    ts_start / 1000000 AS time,\n    concat('tick=', (ts_start - ctf_start_ts) / tick_length, ' ', metadata#>>'{flowvars,0,match}') AS text\nFROM flow, config\nWHERE\n    ts_start * 1000 >= $__unixEpochNanoFrom() and ts_start * 1000 < $__unixEpochNanoTo()\n    AND metadata#>>'{flowvars,0,match}' IS NOT NULL\n    AND (CONCAT(src_ip, ':', src_port) IN (${CTF_SERVICES:singlequote}) OR CONCAT(dest_ip, ':', dest_port) IN (${CTF_SERVICES:singlequote}))\nORDER BY ts_start DESC\nLIMIT 1000",
