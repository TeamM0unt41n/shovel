          "rawQuery": true,
          "rawSql": "WITH config AS (SELECT \n    (1000000 * EXTRACT(EPOCH FROM '${CTF_START_DATE}'::timestamp)) AS ctf_start_ts,\n    (1000000 * '${CTF_TICK_LENGTH}'::bigint) AS tick_length\n)\nSELECT\n    MIN(ts_start) / 1000000 AS time,\n    MIN(FLOOR((ts_start - ctf_start_ts) / tick_length)) as tick,\n    COUNT(*) as flag_out,\n    MIN(ctf_start_ts + FLOOR((ts_start - ctf_start_ts) / tick_length + 1) * tick_length) as ts_to_url\nFROM flow, config\nWHERE\n    ts_start * 1000 >= $__unixEpochNanoFrom() and ts_start * 1000 < $__unixEpochNanoTo()\n    AND id IN (SELECT flow_id FROM alert WHERE tag = 'FLAG OUT')\n    AND (CONCAT(src_ip, ':', src_port) IN (${CTF_SERVICES:singlequote}) OR CONCAT(dest_ip, ':', dest_port) IN (${CTF_SERVICES:singlequote}))\nGROUP BY cast(((ts_start - ctf_start_ts) / 1000000 / ${CTF_TICK_LENGTH}) as int) * ${CTF_TICK_LENGTH}\n",
